<UserControl x:Class="NetworkScanner.UCSetting"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:NetworkScanner"
             xmlns:core="clr-namespace:NetworkScanner;assembly=NetworkScanner.Core"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="1000"  Margin="5" Loaded="UserControl_Loaded" FontFamily="Consolas" Initialized="UserControl_Initialized" >
    <UserControl.Resources>
        <core:ScanRangeList x:Key="ScanRangeList" />
        <SolidColorBrush x:Key="RangeBackgroundBrush" Color="#FF403D54"></SolidColorBrush>
    </UserControl.Resources>
    <Grid VerticalAlignment="Stretch" HorizontalAlignment="Stretch" >
        <Grid.RowDefinitions>
            <RowDefinition Height="80"></RowDefinition>
            <RowDefinition Height="200"></RowDefinition>
            <RowDefinition  Height="60"></RowDefinition>
            <RowDefinition Height="100"></RowDefinition>
            <RowDefinition Height="100"></RowDefinition>
            <RowDefinition  Height="60"></RowDefinition>
            <RowDefinition  Height="60"></RowDefinition>
            <RowDefinition  Height="30"></RowDefinition>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background ="{StaticResource RangeBackgroundBrush}">
            <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition></ColumnDefinition>
                    <ColumnDefinition></ColumnDefinition>
                    <ColumnDefinition Width="150"></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" Grid.Column="0">
                    <Image Margin="10" Source="/img/Setup.png"/>
                    <Label VerticalAlignment="Center" FontSize="24" FontWeight="Bold" FontFamily="Consolas" Foreground="White" Content="{local:Tr Key=settings.title}" />
                </StackPanel>
                <Button Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center" Background="#00DDDDDD" BorderBrush="#00707070" Name="Btn_SaveFile" Click="Btn_SaveFile_Click">
                    <Button.Content>
                        <StackPanel Orientation="Vertical">
                            <Image Margin="3" Height="30" Width="30" Source="/img/save-as-48.png"/>
                            <Label FontWeight="Bold" Foreground="White" Content="{local:Tr Key=settings.save}" />
                        </StackPanel>
                    </Button.Content>
                </Button>
            </Grid>
        </Border>
        <GroupBox Grid.Row="1" Header="{local:Tr Key=settings.iprange}" Background="White" Margin="3">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition ></RowDefinition>
                    <RowDefinition Height="30"></RowDefinition>
                </Grid.RowDefinitions>
            <ListView  Name="LvIPRange"  ItemsSource="{Binding Source={StaticResource ScanRangeList}}">
                <ListView.View>
                    <GridView>
                        <!--GridViewColumn Header="번호" Width="30" DisplayMemberBinding="{Binding Path=Index}">
                    </GridViewColumn-->
                        <GridViewColumn Header="{local:Tr Key=settings.startip}" Width="150">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox  Text="{Binding Path=StartIP, Mode=TwoWay}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" BorderBrush="White"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="{local:Tr Key=settings.endip}" Width="150">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox   Text="{Binding Path=EndIP, Mode=TwoWay}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" BorderBrush="White"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="{local:Tr Key=col.note}" Width="300">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox  Text="{Binding Path=Description, Mode=TwoWay}" BorderBrush="White" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>
            <Grid Grid.Row="1" Background="LightGray">
                <StackPanel Orientation="Horizontal" Margin="3">
                    <StackPanel Orientation="Horizontal">
                        <Label Width="80" Content="{local:Tr Key=settings.startip}" />
                        <TextBox Width="150" Name="tbStartIP"></TextBox>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Label Width="80" Content="{local:Tr Key=settings.endip}" />
                        <TextBox Width="150" Name="tbEndIP"></TextBox>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Label Width="80" Content="{local:Tr Key=settings.desc}" />
                        <TextBox Width="150" Name="tbDescription"></TextBox>
                    </StackPanel>
                    <Border MinWidth="50"></Border>
                    <Button Width="100" Margin="3,0" Name="BtnAddRange" Click="BtnAddRange_Click" Content="{local:Tr Key=settings.addrange}" />
                    <Button Width="100" Margin="3,0" Name="BtnRemoveRange" Click="BtnRemoveRange_Click" Content="{local:Tr Key=settings.removerange}" />
                </StackPanel>
                </Grid>
            </Grid>
        </GroupBox>
        <Border Grid.Row="2" Background="White">
            <GroupBox Header="{local:Tr Key=settings.ports}" Margin="3">
                <StackPanel Orientation="Horizontal" Margin="3">
                    <CheckBox Name="ChkCheckPort" Width="180" Content="{local:Tr Key=settings.useportcheck}" HorizontalAlignment="Center" VerticalAlignment="Center" ></CheckBox>
                    <Label Width="100" Content="{local:Tr Key=settings.portno}" />
                    <TextBox Name="tbPortsList" HorizontalAlignment="Stretch" MinWidth="500">22/80/8080</TextBox>
                </StackPanel>
            </GroupBox>
        </Border>
        <Border Grid.Row="3" Background="White">
            <GroupBox Header="{local:Tr Key=settings.scheduling}" Margin="3">
                <Grid  Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition></RowDefinition>
                        <RowDefinition></RowDefinition>
                        <RowDefinition></RowDefinition>
                    </Grid.RowDefinitions>
                    <CheckBox Name="ChkScheduling" Content="{local:Tr Key=settings.usescheduling}"></CheckBox>
                    <StackPanel Grid.Row="1" Orientation="Horizontal">
                        <CheckBox Name="Chk01" Margin="10,3"></CheckBox>
                        <CheckBox Name="Chk02" Margin="10,3"></CheckBox>
                        <CheckBox Name="Chk03" Margin="10,3"></CheckBox>
                        <CheckBox Name="Chk04" Margin="10,3"></CheckBox>
                        <CheckBox Name="Chk05" Margin="10,3"></CheckBox>
                        <CheckBox Name="Chk06" Margin="10,3"></CheckBox>
                        <CheckBox Name="Chk07" Margin="10,3"></CheckBox>
                        <CheckBox Name="Chk08" Margin="10,3"></CheckBox>
                        <CheckBox Name="Chk09" Margin="10,3"></CheckBox>
                        <CheckBox Name="Chk10" Margin="10,3"></CheckBox>
                        <CheckBox Name="Chk11" Margin="10,3"></CheckBox>
                        <CheckBox Name="Chk12" Margin="10,3"></CheckBox>
                    </StackPanel>
                    <StackPanel Grid.Row="2" Orientation="Horizontal">
                        <CheckBox Name="Chk13" Margin="10,3"></CheckBox>
                        <CheckBox Name="Chk14" Margin="10,3"></CheckBox>
                        <CheckBox Name="Chk15" Margin="10,3"></CheckBox>
                        <CheckBox Name="Chk16" Margin="10,3"></CheckBox>
                        <CheckBox Name="Chk17" Margin="10,3"></CheckBox>
                        <CheckBox Name="Chk18" Margin="10,3"></CheckBox>
                        <CheckBox Name="Chk19" Margin="10,3"></CheckBox>
                        <CheckBox Name="Chk20" Margin="10,3"></CheckBox>
                        <CheckBox Name="Chk21" Margin="10,3"></CheckBox>
                        <CheckBox Name="Chk22" Margin="10,3"></CheckBox>
                        <CheckBox Name="Chk23" Margin="10,3"></CheckBox>
                        <CheckBox Name="Chk24" Margin="10,3"></CheckBox>

                    </StackPanel>
                </Grid>
            </GroupBox>
          
        </Border>
        <Border Grid.Row="4" Background="White">
            <GroupBox Header="{local:Tr Key=settings.filelocation}" Margin="3">
                <GroupBox Header="{local:Tr Key=settings.ftpsave}" Margin="3">
                    <StackPanel Margin="3">
                        <CheckBox Name="ChkUseFTP" Height="20" Content="{local:Tr Key=settings.useftp}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition></ColumnDefinition>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Width="80" FontWeight="Normal" TextAlignment="Right">Host</TextBlock>
                                <TextBox Name="TbFTPIP" Width="200"></TextBox>
                                <TextBlock Width="80" TextAlignment="Right">ID</TextBlock>
                                <TextBox Name="TbFTPID" Width="150"></TextBox>
                                <TextBlock Width="80" TextAlignment="Right">PW</TextBlock>
                                <PasswordBox Name="TbFTPPW" Width="150"></PasswordBox>
                                <TextBlock Width="80" TextAlignment="Right">Port</TextBlock>
                                <TextBox Name="TbFTPPort" Width="100"></TextBox>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </GroupBox>
            </GroupBox>
        </Border>
        <Border Grid.Row="5" Background="White">
            <GroupBox Header="{local:Tr Key=settings.general}" Margin="3">
                <StackPanel Orientation="Horizontal" Margin="3">
                    <Label Width="100" Content="{local:Tr Key=settings.systemname}" />
                    <TextBox Name="tbCurSystemName" Width="200" Margin="3">MyComputer</TextBox>
                    <Border Width="40"></Border>
                    <CheckBox Name="chkLoadLastestFileWhenStartup" Margin="3" VerticalAlignment="Center" IsChecked="True" Content="{local:Tr Key=settings.loadlatest}" />
                    <Border Width="20"></Border>
                    <CheckBox Name="ChkContinuousMonitoring" Margin="3" VerticalAlignment="Center" Content="{local:Tr Key=settings.continuous}" />
                    <TextBox Name="tbMonitorInterval" Width="50" Margin="3" VerticalAlignment="Center">10</TextBox>
                    <Label VerticalAlignment="Center" Content="{local:Tr Key=settings.interval}" />
                    <Border Width="30"></Border>
                    <Label VerticalAlignment="Center" Content="{local:Tr Key=settings.language}"/>
                    <ComboBox Name="CmbLanguage" Width="110" Margin="3" VerticalAlignment="Center">
                        <ComboBoxItem Tag="en">English</ComboBoxItem>
                        <ComboBoxItem Tag="ko">한국어</ComboBoxItem>
                    </ComboBox>
                    <Label VerticalAlignment="Center" Content="{local:Tr Key=settings.lang.restart}"/>
                </StackPanel>
            </GroupBox>
        </Border>
        <Border Grid.Row="6" Background="White" Visibility="Hidden">
            <GroupBox Header="Update" Margin="3">
                <StackPanel Orientation="Horizontal" Margin="3">
                    <Label Width="120">Cur version</Label>
                    <TextBox Name="tbCurVersion" Width="200"></TextBox>
                    <Label Width="120">Lastest version</Label>
                    <TextBox Name="tbLastestVersion" Width="200">unknown</TextBox>
                    <Border Width="120"></Border>
                    <Button Name="btnUpdate" Width="120" Click="btnUpdate_Click"> Update</Button>
                </StackPanel>
            </GroupBox>
        </Border>
        <Border Grid.Row="7" Background="White">
            <TextBlock  Background="White" Name="tbMsg" Margin="3"></TextBlock>
        </Border>
    </Grid>
</UserControl>
