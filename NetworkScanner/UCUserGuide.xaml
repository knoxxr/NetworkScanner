<UserControl x:Class="NetworkScanner.UCUserGuide"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:NetworkScanner"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="#FF303030">
        <Grid.RowDefinitions>
            <RowDefinition Height="60" />
            <RowDefinition />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="16,16,16,0">
            <StackPanel Orientation="Horizontal">
                <Image Source="/img/document-48.png" Width="28" Height="28" />
                <Label FontSize="18" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"
                       Content="{local:Tr Key=guide.title}" />
            </StackPanel>
            <!-- 설명서 언어는 앱 UI 언어(en/ko)와 별개로 즉시 전환된다(영어 기본, 한/일/중 지원). -->
            <ComboBox Name="CbLanguage" Width="140" Height="26" HorizontalAlignment="Right" VerticalAlignment="Center"
                      SelectionChanged="CbLanguage_SelectionChanged" />
        </Grid>

        <ScrollViewer Grid.Row="1" Margin="16,12,16,16" VerticalScrollBarVisibility="Auto">
            <StackPanel Name="PnlSections" MaxWidth="900" HorizontalAlignment="Left" />
        </ScrollViewer>
    </Grid>
</UserControl>
