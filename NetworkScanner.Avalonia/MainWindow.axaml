<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="700"
        x:Class="NetworkScanner.Avalonia.MainWindow"
        Icon="avares://NetworkScanner.Avalonia/Assets/app.ico"
        Title="Network Scanner" Width="1280" Height="700" Loaded="Window_Loaded">
    <Window.Resources>
        <SolidColorBrush x:Key="SideBackgroundBrush" Color="#FF252469" />
        <SolidColorBrush x:Key="SideActiveBackgroundBrush" Color="#FF32407A" />
        <SolidColorBrush x:Key="AccentBrush" Color="#FF46C2B8" />
    </Window.Resources>
    <Grid ColumnDefinitions="140,*">
        <Border Grid.Column="0" Background="{StaticResource SideBackgroundBrush}">
            <Grid RowDefinitions="80,*,Auto">
                <TextBlock Grid.Row="0" FontSize="16" FontWeight="Bold" Foreground="White"
                           Margin="12" TextWrapping="Wrap" VerticalAlignment="Center">Network Scanner</TextBlock>
                <StackPanel Grid.Row="1" Spacing="4">
                    <Button Name="BtnIPList" Click="BtnIPList_Click" HorizontalAlignment="Stretch"
                            Background="{StaticResource SideBackgroundBrush}" BorderBrush="Transparent" BorderThickness="3,0,0,0">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Image Source="avares://NetworkScanner.Avalonia/Assets/iplist.png" Width="24" Height="24" />
                            <TextBlock VerticalAlignment="Center">IP 리스트</TextBlock>
                        </StackPanel>
                    </Button>
                    <Button Name="BtnSetting" Click="BtnSetting_Click" HorizontalAlignment="Stretch"
                            Background="{StaticResource SideBackgroundBrush}" BorderBrush="Transparent" BorderThickness="3,0,0,0">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Image Source="avares://NetworkScanner.Avalonia/Assets/settings.png" Width="24" Height="24" />
                            <TextBlock VerticalAlignment="Center">설정</TextBlock>
                        </StackPanel>
                    </Button>
                    <Button Name="BtnPortInfo" Click="BtnPortInfo_Click" HorizontalAlignment="Stretch"
                            Background="{StaticResource SideBackgroundBrush}" BorderBrush="Transparent" BorderThickness="3,0,0,0">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Image Source="avares://NetworkScanner.Avalonia/Assets/info.png" Width="24" Height="24" />
                            <TextBlock VerticalAlignment="Center">참고. 포트정보</TextBlock>
                        </StackPanel>
                    </Button>
                </StackPanel>
                <StackPanel Grid.Row="2" Margin="0,0,0,12">
                    <TextBlock Name="TbVersion" Foreground="White" TextAlignment="Center">version</TextBlock>
                </StackPanel>
            </Grid>
        </Border>
        <ContentControl Grid.Column="1" Name="ContentArea" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
    </Grid>
</Window>
