<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:helpers="clr-namespace:NetworkScanner.Avalonia.Helpers"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="700"
             x:Class="NetworkScanner.Avalonia.Views.IPListView">

    <UserControl.Resources>
        <helpers:StatusColorConverter x:Key="StatusColorConverter" />
        <SolidColorBrush x:Key="StatusGoodBrush" Color="#FF34C777" />
        <SolidColorBrush x:Key="StatusWarnBrush" Color="#FFF3A53E" />
        <SolidColorBrush x:Key="StatusBadBrush" Color="#FFEF5875" />
    </UserControl.Resources>

    <Grid RowDefinitions="Auto,Auto,*,Auto,Auto">
        <Border Grid.Row="0" Background="#FF326678" Padding="12">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <TextBlock Grid.Column="0" FontSize="22" FontWeight="Bold" Foreground="White"
                           VerticalAlignment="Center" Margin="0,0,24,0" Text="{helpers:Tr Key=iplist.title}" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Button Name="BtnNewFile" Click="BtnNewFile_Click">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Image Source="avares://NetworkScanner.Avalonia/Assets/new-file.png" Width="20" Height="20" />
                            <TextBlock VerticalAlignment="Center" Text="{helpers:Tr Key=btn.new}" />
                        </StackPanel>
                    </Button>
                    <Button Name="BtnLoadFile" Click="BtnLoadFile_Click">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Image Source="avares://NetworkScanner.Avalonia/Assets/open-file.png" Width="20" Height="20" />
                            <TextBlock VerticalAlignment="Center" Text="{helpers:Tr Key=btn.open}" />
                        </StackPanel>
                    </Button>
                    <Button Name="BtnSaveFile" Click="BtnSaveFile_Click">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Image Source="avares://NetworkScanner.Avalonia/Assets/save-file.png" Width="20" Height="20" />
                            <TextBlock VerticalAlignment="Center" Text="{helpers:Tr Key=btn.save}" />
                        </StackPanel>
                    </Button>
                    <Button Name="BtnReport" Click="BtnReport_Click">
                        <TextBlock VerticalAlignment="Center" Text="{helpers:Tr Key=btn.report}" />
                    </Button>
                </StackPanel>
                <StackPanel Grid.Column="2" HorizontalAlignment="Right" Spacing="4">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button Name="BtnRefresh" Click="BtnRefresh_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Image Source="avares://NetworkScanner.Avalonia/Assets/refresh.png" Width="20" Height="20" />
                                <TextBlock Name="TbScanLabel" VerticalAlignment="Center" Text="{helpers:Tr Key=btn.scan}" />
                            </StackPanel>
                        </Button>
                        <Button Name="BtnStop" Click="BtnStop_Click" IsEnabled="False" Content="{helpers:Tr Key=btn.cancel}" />
                    </StackPanel>
                    <TextBlock Name="TbResult" Foreground="White" HorizontalAlignment="Right" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="Auto,*" Margin="12,6">
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
                <TextBlock Text="{helpers:Tr Key=label.search}" VerticalAlignment="Center" />
                <TextBox Name="TbSearch" Width="160" VerticalAlignment="Center"
                         Watermark="{helpers:Tr Key=search.watermark}" TextChanged="TbSearch_TextChanged" />
                <CheckBox Name="ChkAliveOnly" Content="{helpers:Tr Key=filter.aliveonly}" VerticalAlignment="Center" IsCheckedChanged="ChkAliveOnly_Changed" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Spacing="4">
                <Ellipse Width="10" Height="10" Fill="{StaticResource StatusGoodBrush}" />
                <TextBlock Text="{helpers:Tr Key=legend.up}" Margin="0,0,12,0" VerticalAlignment="Center" />
                <Ellipse Width="10" Height="10" Fill="{StaticResource StatusWarnBrush}" />
                <TextBlock Text="{helpers:Tr Key=legend.warn}" Margin="0,0,12,0" VerticalAlignment="Center" />
                <Ellipse Width="10" Height="10" Fill="{StaticResource StatusBadBrush}" />
                <TextBlock Text="{helpers:Tr Key=legend.down}" VerticalAlignment="Center" />
            </StackPanel>
        </Grid>

        <DataGrid Grid.Row="2" Name="DgIPList" AutoGenerateColumns="False" CanUserSortColumns="True" CanUserResizeColumns="True" FontFamily="Cascadia Code,Consolas,monospace">
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="{helpers:Tr Key=menu.ping}" Click="MenuItemPing_Click" />
                    <MenuItem Header="{helpers:Tr Key=menu.checkport}" Click="MenuItemCheckPort_Click" />
                    <MenuItem Header="{helpers:Tr Key=menu.checkreserved}" Click="MenuItemCheckReservedPort_Click" />
                    <MenuItem Header="{helpers:Tr Key=menu.checkprohibit}" Click="MenuItemCheckProhibitPort_Click" />
                    <Separator />
                    <MenuItem Header="{helpers:Tr Key=menu.wol}" Click="MenuItemWakeOnLan_Click" />
                    <Separator />
                    <MenuItem Header="{helpers:Tr Key=menu.remove}" Click="MenuItemRemove_Click" />
                </ContextMenu>
            </DataGrid.ContextMenu>
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="{helpers:Tr Key=col.status}" Width="90" SortMemberPath="StatusText">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="6,0">
                                <Ellipse Width="10" Height="10" Margin="0,0,5,0" VerticalAlignment="Center"
                                         Fill="{Binding StatusKey, Converter={StaticResource StatusColorConverter}}" />
                                <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" FontFamily="Segoe UI,Inter,sans-serif" FontSize="12" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="{helpers:Tr Key=col.ip}" Binding="{Binding Ip}" IsReadOnly="True" Width="140" />
                <DataGridTextColumn Header="{helpers:Tr Key=col.name}" Binding="{Binding SystemName}" Width="160" />
                <DataGridTextColumn Header="{helpers:Tr Key=col.type}" Binding="{Binding DeviceType}" IsReadOnly="True" Width="120" />
                <DataGridTextColumn Header="{helpers:Tr Key=col.os}" Binding="{Binding OsGuess}" IsReadOnly="True" Width="120" />
                <DataGridTextColumn Header="{helpers:Tr Key=col.ports}" Binding="{Binding Ports}" Width="140" />
                <DataGridTextColumn Header="{helpers:Tr Key=col.service}" Binding="{Binding Service}" IsReadOnly="True" Width="180" />
                <DataGridTextColumn Header="{helpers:Tr Key=col.mac}" Binding="{Binding Macaddr}" Width="160" />
                <DataGridTextColumn Header="{helpers:Tr Key=col.vendor}" Binding="{Binding Vendor}" Width="160" />
                <DataGridTextColumn Header="{helpers:Tr Key=col.rtt}" Binding="{Binding RountTime}" IsReadOnly="True" Width="120" />
                <DataGridTextColumn Header="{helpers:Tr Key=col.note}" Binding="{Binding Description}" Width="240" />
                <DataGridTextColumn Header="{helpers:Tr Key=col.created}" Binding="{Binding CommitDate}" IsReadOnly="True" Width="160" />
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="3">
            <ProgressBar Name="PbProgress" Height="20" Margin="12,2" Foreground="#FF46C2B8" />
            <TextBlock Name="TbProgressPercent" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" FontWeight="Bold" />
        </Grid>
        <TextBlock Grid.Row="4" Name="TbMsg" Margin="4" />
    </Grid>
</UserControl>
