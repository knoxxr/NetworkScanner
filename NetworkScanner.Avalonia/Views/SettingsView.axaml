<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:l="clr-namespace:NetworkScanner.Avalonia.Helpers"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="800"
             x:Class="NetworkScanner.Avalonia.Views.SettingsView">
    <ScrollViewer>
        <StackPanel Margin="12" Spacing="12">

            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10">
                    <Image Source="avares://NetworkScanner.Avalonia/Assets/setup.png" Width="28" Height="28" />
                    <TextBlock FontSize="22" FontWeight="Bold" VerticalAlignment="Center" Text="{l:Tr Key=settings.title}" />
                </StackPanel>
                <Button Grid.Column="1" Name="BtnSaveFile" Click="BtnSaveFile_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Image Source="avares://NetworkScanner.Avalonia/Assets/save-file.png" Width="20" Height="20" />
                        <TextBlock VerticalAlignment="Center" Text="{l:Tr Key=settings.save}" />
                    </StackPanel>
                </Button>
            </Grid>

            <Border BorderBrush="Gray" BorderThickness="1" Padding="8">
                <StackPanel Spacing="8">
                    <TextBlock FontWeight="Bold" Text="{l:Tr Key=settings.iprange}" />
                    <DataGrid Name="DgIPRange" Height="200" AutoGenerateColumns="False" CanUserResizeColumns="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{l:Tr Key=settings.startip}" Binding="{Binding StartIP}" Width="150" />
                            <DataGridTextColumn Header="{l:Tr Key=settings.endip}" Binding="{Binding EndIP}" Width="150" />
                            <DataGridTextColumn Header="{l:Tr Key=col.note}" Binding="{Binding Description}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Width="70" VerticalAlignment="Center" Text="{l:Tr Key=settings.startip}" />
                        <TextBox Name="TbStartIP" Width="150" Watermark="192.168.1.0/24" />
                        <TextBlock Width="70" VerticalAlignment="Center" Text="{l:Tr Key=settings.endip}" />
                        <TextBox Name="TbEndIP" Width="150" />
                        <TextBlock Width="50" VerticalAlignment="Center" Text="{l:Tr Key=settings.desc}" />
                        <TextBox Name="TbDescription" Width="150" />
                        <Button Name="BtnAddRange" Click="BtnAddRange_Click" Content="{l:Tr Key=settings.addrange}" />
                        <Button Name="BtnRemoveRange" Click="BtnRemoveRange_Click" Content="{l:Tr Key=settings.removerange}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border BorderBrush="Gray" BorderThickness="1" Padding="8">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock FontWeight="Bold" VerticalAlignment="Center" Text="{l:Tr Key=settings.ports}" />
                    <CheckBox Name="ChkCheckPort" Content="{l:Tr Key=settings.useportcheck}" />
                    <TextBlock VerticalAlignment="Center" Text="{l:Tr Key=settings.portno}" />
                    <TextBox Name="TbPortsList" Width="400" Watermark="22/80/8080" />
                </StackPanel>
            </Border>

            <Border BorderBrush="Gray" BorderThickness="1" Padding="8">
                <StackPanel Spacing="8">
                    <CheckBox Name="ChkScheduling" Content="{l:Tr Key=settings.usescheduling}" FontWeight="Bold" />
                    <WrapPanel Name="HourCheckboxPanel" />
                </StackPanel>
            </Border>

            <Border BorderBrush="Gray" BorderThickness="1" Padding="8">
                <StackPanel Spacing="8">
                    <CheckBox Name="ChkUseFTP" Content="{l:Tr Key=settings.useftp}" FontWeight="Bold" />
                    <WrapPanel>
                        <TextBlock Width="60" VerticalAlignment="Center">Host</TextBlock>
                        <TextBox Name="TbFTPIP" Width="180" Margin="0,0,12,0" />
                        <TextBlock Width="40" VerticalAlignment="Center">ID</TextBlock>
                        <TextBox Name="TbFTPID" Width="140" Margin="0,0,12,0" />
                        <TextBlock Width="40" VerticalAlignment="Center">PW</TextBlock>
                        <TextBox Name="TbFTPPW" Width="140" PasswordChar="●" Margin="0,0,12,0" />
                        <TextBlock Width="50" VerticalAlignment="Center">Port</TextBlock>
                        <TextBox Name="TbFTPPort" Width="100" />
                    </WrapPanel>
                </StackPanel>
            </Border>

            <Border BorderBrush="Gray" BorderThickness="1" Padding="8">
                <WrapPanel>
                    <TextBlock FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,0" Text="{l:Tr Key=settings.general}" />
                    <TextBlock Width="90" VerticalAlignment="Center" Text="{l:Tr Key=settings.systemname}" />
                    <TextBox Name="TbCurSystemName" Width="200" Margin="0,0,16,0" />
                    <CheckBox Name="ChkLoadLatestFileWhenStartup" Content="{l:Tr Key=settings.loadlatest}" Margin="0,0,24,0" />
                    <CheckBox Name="ChkContinuousMonitoring" Content="{l:Tr Key=settings.continuous}" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <TextBox Name="TbMonitorInterval" Width="50" Text="10" VerticalAlignment="Center" />
                    <TextBlock VerticalAlignment="Center" Margin="6,0,0,0" Text="{l:Tr Key=settings.interval}" />
                </WrapPanel>
            </Border>

            <Border BorderBrush="Gray" BorderThickness="1" Padding="8">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock FontWeight="Bold" VerticalAlignment="Center" Text="{l:Tr Key=settings.language}" />
                    <ComboBox Name="CmbLanguage" Width="160" VerticalAlignment="Center">
                        <ComboBoxItem Tag="en">English</ComboBoxItem>
                        <ComboBoxItem Tag="ko">한국어</ComboBoxItem>
                    </ComboBox>
                    <TextBlock VerticalAlignment="Center" Text="{l:Tr Key=settings.lang.restart}" />
                </StackPanel>
            </Border>

            <TextBlock Name="TbMsg" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
