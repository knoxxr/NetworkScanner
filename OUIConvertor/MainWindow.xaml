<Window x:Class="OUIConvertor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OUIConvertor"
        mc:Ignorable="d"
        Title="MainWindow" Height="120" Width="800" Loaded="Window_Loaded">
    <StackPanel>
        <Label Name="lbProgress" Width="130" Height="30">0</Label>
        <ProgressBar Name="ProgBar" HorizontalAlignment="Stretch"></ProgressBar>
        <Button Height="30" Margin="3" Click="Button_Click">refresh</Button>
    </StackPanel>
</Window>
